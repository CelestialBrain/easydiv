{
  "name": "easydiv",
  "version": "2.1.0",
  "description": "Chrome extension that scrapes UI components from any site as Tailwind CSS, inline styles, or React/JSX. Auto-detects components page-wide. Open source, local-only, no AI.",
  "main": "background.js",
  "scripts": {
    "test": "node test/test_pxToTw.js && node test/test_detector.js",
    "test:e2e": "node test/test_e2e.js",
    "test:ext": "node test/test_extension.js",
    "test:fidelity": "node test/test_fidelity.js",
    "test:all": "npm run test && npm run test:e2e && npm run test:ext && npm run test:fidelity"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CelestialBrain/easydiv.git"
  },
  "keywords": [
    "chrome-extension",
    "tailwindcss",
    "tailwind",
    "css",
    "html",
    "jsx",
    "react",
    "devtools",
    "scraper",
    "ui-components",
    "design-extraction"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/CelestialBrain/easydiv/issues"
  },
  "homepage": "https://github.com/CelestialBrain/easydiv#readme",
  "devDependencies": {
    "jsdom": "^29.0.2",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  }
}
